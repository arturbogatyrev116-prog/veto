# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL password (change before deploying)
POSTGRES_PASSWORD=change_me_before_deploy

# Admin API token — keep this secret, used for user management
ADMIN_TOKEN=change_me_before_deploy

# ── Optional ──────────────────────────────────────────────────────────────────

# PostgreSQL database / user (defaults shown)
# POSTGRES_DB=messenger
# POSTGRES_USER=messenger

# Port exposed on the host (default: 3000)
# BIND_PORT=3000

# ── TLS — choose one option ───────────────────────────────────────────────────

# Option A: Let's Encrypt or your own certificate files (production)
# CERTS_DIR=/etc/letsencrypt/live/messenger.yourdomain.com
# TLS_CERT_PATH=/certs/fullchain.pem
# TLS_KEY_PATH=/certs/privkey.pem

# Option B: Auto-generate self-signed certificate (testing / LAN only)
# TLS_SELF_SIGNED=1

# ── Registration ──────────────────────────────────────────────────────────────

# Allow self-registration via POST /api/v1/register.
# Set to 1 during onboarding, then remove to lock down new signups.
# Default: closed (only admin can create users via admin API).
# REGISTRATION_OPEN=1
