{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veto",
  "version": "0.1.0",
  "identifier": "com.veto.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Veto",
        "width": 900,
        "height": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER_REPLACE_WITH_YOUR_PUBLIC_KEY",
      "endpoints": [
        "https://your-server.com/api/v1/updates/{{target}}/{{current_version}}"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "End-to-end encrypted messenger",
    "longDescription": "Veto is a secure, on-premise messenger with post-quantum encryption. All messages are end-to-end encrypted and never stored in plaintext on the server.",
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsi"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
